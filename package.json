{
  "name": "reskflow",
  "version": "1.0.0",
  "description": "ReskFlow - Enterprise blockchain-based delivery platform",
  "private": true,
  "workspaces": [
    "blockchain",
    "backend/*",
    "frontend/*",
    "mobile/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:blockchain\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:blockchain": "npm run dev --workspace=blockchain",
    "dev:backend": "npm run dev --workspace=backend/gateway",
    "dev:frontend": "npm run dev --workspace=frontend/customer",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write .",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^8.0.3",
    "prettier": "^3.1.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}