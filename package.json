{
  "name": "reskflow",
  "version": "1.0.0",
  "description": "ReskFlow - Enterprise blockchain-based delivery platform",
  "private": true,
  "workspaces": [
    "blockchain",
    "backend/*",
    "frontend/*",
    "mobile/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:blockchain\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:blockchain": "npm run dev --workspace=blockchain",
    "dev:backend": "npm run dev --workspace=backend/gateway",
    "dev:frontend": "npm run dev --workspace=frontend/customer",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:unit": "jest --testPathPattern=unit --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:contract": "jest --testPathPattern=contract",
    "test:e2e": "playwright test",
    "test:performance": "cd testing/performance && ./run-performance-tests.sh",
    "test:security": "cd testing/security && ./run-security-tests.sh",
    "test:chaos": "cd testing/chaos && ./run-chaos-tests.sh",
    "test:all": "cd testing && ./run-all-tests.sh",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write .",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}